+  // Filter & Grouping Logic
+  const filteredAndGroupedData = useMemo(() => {
+    if (!dashboardData) return [];
+
+    const groups: Record<number, any> = {};
+
+    // Helper to ensure group exists
+    const ensureGroup = (pId: number, pNama: string) => {
+      if (!groups[pId]) {
+        const pDet = pelangganData?.find(p => p.id === pId);
+        groups[pId] = {
+          id: pId,
+          name: pNama,
+          saldoPoin: pDet?.totalPoint || 0,
+          totalCair: 0,
+          ready: [],
+          history: []
+        };
+      }
+    };
+
+    // 1. Process Ready Data
+    const { ready } = dashboardData;
+    ready.cashback.forEach((item: any) => {
+       ensureGroup(item.pelangganId, item.pelangganNama);
+       groups[item.pelangganId].ready.push({ ...item, type: 'cashback', label: 'Cashback' });
+    });
+    ready.points.forEach((item: any) => {
+       ensureGroup(item.pelangganId, item.pelangganNama);
+       groups[item.pelangganId].ready.push({ ...item, type: 'point', label: 'Loyalty Points', nilai: item.saldo });
+    });
+    ready.labels.forEach((item: any) => {
+       ensureGroup(item.pelangganId, item.pelangganNama);
+       groups[item.pelangganId].ready.push({ ...item, type: 'cutting', label: `Label: ${item.namaPromo}`, nilai: item.totalNilai });
+    });
+    ready.pakets.forEach((item: any) => {
+       ensureGroup(item.pelangganId, item.pelangganNama);
+       groups[item.pelangganId].ready.push({ ...item, type: 'paket', label: `Paket: ${item.namaPaket}`, nilai: item.targetVal || 0, desc: item.target });
+    });
+
+    // 2. Process History
+    dashboardData.history.forEach((item: any) => {
+       ensureGroup(item.pelangganId, item.pelanggan.name);
+       groups[item.pelangganId].history.push(item);
+       groups[item.pelangganId].totalCair += Number(item.jumlah);
+    });
+
+    // Filtering
+    let result = Object.values(groups);
+    if (searchTerm) {
+      const lowerSearch = searchTerm.toLowerCase();
+      result = result.filter(g => g.name.toLowerCase().includes(lowerSearch));
+    }
+    if (selectedPelangganId !== "all") {
+      result = result.filter(g => g.id.toString() === selectedPelangganId);
+    }
+
+    return result.sort((a, b) => a.name.localeCompare(b.name));
+  }, [dashboardData, searchTerm, selectedPelangganId, pelangganData]);
